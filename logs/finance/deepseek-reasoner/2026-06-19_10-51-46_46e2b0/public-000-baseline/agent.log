        output='[{"url": "https://www.vcpost.com/articles/128786/20250106/biden-faces-lawsuit-nippon-us-steel-after-blocking-their-15b-merger.htm", "title": "Biden Faces Lawsuit From Nippon, US Steel After Blocking Their $15B Merger", "content": "Nippon Steel and US Steel were supposed to break the industry with a $15 billion merger until outgoing US President Joe Biden blocked the deal over national security concerns.\\n\\nIn response, the two steelmaker giants are suing the Biden administration. The newly filed lawsuit was sent to the US Court of Appeals for the District of Columbia, which claimed that the decision was an obvious politically motivated one, and violated the rights of the companies to due process.", "score": 0.6737291, "raw_content": null}, {"url": "https://franchiseherald.com/articles/235727/20250107/biden-faces-lawsuit-us-steel-nippon-steel-after-blocking-15-billion-merger.htm", "title": "Biden Faces Lawsuit From US Steel, Nippon Steel After Blocking $15 Billion Merger", "content": "logo\\n\\nCopyright \\u00a9 2026 Franchise Herald. All rights reserved.\\n\\n## Search Here\\n\\nFranchise News\\n\\n# Biden Faces Lawsuit From US Steel, Nippon Steel After Blocking $15 Billion Merger\\n\\n| By   Madz Dizon\\n\\nNippon Steel Chairman and CEO Eiji Hashimoto speaks during a press conference at the company\'s head office in Tokyo on January 7, 2025. AFP via Getty Images/KAZUHIRO NOGI", "score": 0.6693348, "raw_content": null}, {"url": "https://ruralradio.com/rrn/abc_news/us-steel-and-nippon-steel-sue-biden-administration-over-blocked-merger-abcid2a70fe0a", "title": "US Steel and Nippon Steel sue Biden administration over blocked merger - Rural Radio Network", "content": "U.S. Steel and Nippon Steel also filed a second lawsuit against Cleveland-Cliffs, another domestic steelmaker, as well as USW President David McCall, alleging they illegally coordinated efforts to stop the merger.\\n\\nCleveland-Cliffs sought a merger of its own with U.S. Steel, the lawsuit alleges. In the absence of such a merger, Cleveland-Cliffs established an agreement with USW to prevent the acquisition of U.S. Steel by Nippon Steel, the lawsuit claims.", "score": 0.65359193, "raw_content": null}, {"url": "https://www.yahoo.com/news/nippon-steel-us-steel-sue-202900490.html", "title": "Nippon Steel and US Steel sue Biden administration over blocked merger", "content": "U.S. Steel and Japanese steelmaker Nippon Steel sued the U.S. government Monday in a last-ditch effort to move forward with their merger, which President Biden blocked Friday over national security concerns.The new lawsuit accuses Biden of interfering in the merger review process for political gain and to curry favor with the United Steelworkers Union (USW).The companies in a separate lawsuit on Monday alleged the USW illegally colluded with steelmaker Cleveland-Cliffs, which previously tried", "score": 0.643173, "raw_content": null}, {"url": "https://abcnews.com/amp/Business/us-steel-nippon-steel-sue-biden-administration-blocked/story?id=117375339", "title": "US Steel and Nippon Steel sue Biden administration over blocked merger - ABC News", "content": "U.S. Steel and Nippon Steel also filed a second lawsuit against Cleveland-Cliffs, another domestic steelmaker, as well as USW President David McCall, alleging they illegally coordinated efforts to stop the merger.\\n\\nCleveland-Cliffs sought a merger of its own with U.S. Steel, the lawsuit alleges. In the absence of such a merger, Cleveland-Cliffs established an agreement with USW to prevent the acquisition of U.S. Steel by Nippon Steel, the lawsuit claims.", "score": 0.64020914, "raw_content": null}, {"url": "https://www.euronews.com/2025/01/07/us-steel-and-nippon-file-lawsuit-after-biden-blocks-merger-deal", "title": "US Steel and Nippon file lawsuit after Biden blocks merger deal | Euronews", "content": "Nippon Steel and US Steel filed a federal lawsuit on Monday challenging a Biden administration decision to block Nippon\'s proposed $15bn (\\u20ac14bn) acquisition of the Pittsburgh company.\\n\\nThe firms claimed that the head of the Steelworkers union and a rival steelmaker worked together to scuttle the buyout.\\n\\nIn moving to block the transaction on Friday, Biden said US companies producing a large amount of steel needed to \\"keep leading the fight on behalf of America\\u2019s national interests\\".", "score": 0.63125396, "raw_content": null}, {"url": "https://www.tag24.com/en/politics/politicians/joe-biden/biden-administration-hit-with-lawsuit-from-nippon-steel-and-us-steel-over-blocked-merger-3348695", "title": "Biden administration hit with lawsuit from Nippon Steel and US Steel over blocked merger | TAG24", "content": "Nippon Steel and US Steel filed suit Monday over President Joe Biden\'s decision to block the Japanese giant\'s proposed acquisition of its American rival. \\n\\nNippon Steel and US Steel filed suit Monday over President Joe Biden\'s decision to block the Japanese giant\'s proposed acquisition of its American rival.  \\u00a9 Chris Kleponis / AFP\\n\\nThe companies said in a statement that they had initiated legal action in the US court of appeals in Washington challenging the review process for the acquisition.", "score": 0.6219319, "raw_content": null}, {"url": "https://www.reuters.com/legal/government/nippon-steel-asks-us-court-reject-baseless-consumer-lawsuit-over-us-steel-bid-2025-03-20", "title": "Nippon Steel asks US court to reject \\u2018baseless\\u2019 consumer lawsuit over U.S. Steel bid | Reuters", "content": "in violation of federal antitrust law. Nippon Steel and U.S. Steel sued over the decision, telling the U.S. Court of Appeals for the D.C. Circuit that the order blocking the merger was \\u201cblatantly unconstitutional.\\u201d. Nippon Steel and U.S. Steel have defended the deal, saying it would help U.S. manufacturing compete with China and provide greater job security for American steelworkers. Nippon Steel, U.S. District Court, Northern District of California, No. 3:25-cv-01240. Trump administration", "score": 0.6044228, "raw_content": null}, {"url": "https://www.cnbc.com/video/2025/01/07/us-steel-ceo-on-lawsuit-to-biden-administration-following-dissolved-merger-with-nippon-steel.html", "title": "US Steel CEO on lawsuit to Biden administration following dissolved merger with Nippon Steel", "content": "David Burritt, US Steel CEO, joins \'Squawk on the Street\' to discuss the company\'s decision to partner with Nippon Steel to sue the Biden administration following the fallen merger.\\n\\n03:59\\n\\nTue, Jan 7 202511:18 AM EST\\n\\nwatch now\\n\\nwatch now\\n\\nVIDEO04:11\\n\\nCME CEO Terry Duffy on suing CFTC: I\'m always up for a good battle, \'I won\'t shy away from this\'\\n\\nwatch now\\n\\nwatch now\\n\\nVIDEO10:55\\n\\nWatch CNBC\'s full interview with outgoing CME CEO Terry Duffy\\n\\nwatch now\\n\\nwatch now\\n\\nVIDEO00:55", "score": 0.46672463, "raw_content": null}, {"url": "https://gmk.center/en/news/biden-plans-to-block-the-merger-of-nippon-steel-and-us-steel-bloomberg", "title": "Biden plans to block the merger of Nippon Steel and US Steel - Bloomberg", "content": "Halina Yermolenko\\n\\n## CFIUS is due to deliver its decision on December 22-23\\n\\nUS President Joe Biden plans to officially block the sale of US Steel to Japan\\u2019s Nippon Steel for national security reasons after the Committee on Foreign Investment in the United States (CFIUS) makes its decision. Bloomberg reports, citing sources.\\n\\nThe CFIUS, which has been considering the proposed takeover for most of this year, is expected to deliver its decision to Biden by December 22-23.", "score": 0.4018996, "raw_content": null}]',
